{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=./data/audios.db"
  },
  "Storage": {
    "LocalPath": "./filestore"
  },
  "Upload": {
    "MaxSizeBytes": 52428800,
    "AllowedExtensions": [ ".mp3", ".wav", ".ogg", ".flac", ".m4a", ".aac", ".webm" ]
  },
  "Compression": {
    "FfmpegPath": "ffmpeg",
    "BitrateKbps": 128
  }
}
